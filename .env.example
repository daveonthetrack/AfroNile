# Database
DATABASE_URL="postgresql://postgres:password123@localhost:5435/artist_platform_db"

# Auth — required, minimum 32 random bytes
JWT_SECRET="change-me-to-a-long-random-secret"

# App URL — required in production
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe — required for payments
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Email — optional, ticket/donation confirmations skipped if unset
RESEND_API_KEY="re_..."

# Audio signing — optional, defaults to JWT_SECRET
ASSET_SIGNING_SECRET="change-me-to-a-separate-signing-secret"
