{
  "name": "artist-platform-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready open-source Artist Platform Monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter=@repo/web dev",
    "build": "pnpm --recursive build",
    "start": "pnpm --filter=@repo/web start",
    "db:generate": "pnpm --filter=@repo/database run db:generate",
    "db:migrate": "pnpm --filter=@repo/database run db:migrate",
    "db:deploy": "pnpm --filter=@repo/database run db:deploy",
    "db:seed": "pnpm --filter=@repo/database run db:seed",
    "db:push": "pnpm --filter=@repo/database exec prisma db push",
    "db:studio": "pnpm --filter=@repo/database exec prisma studio"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
