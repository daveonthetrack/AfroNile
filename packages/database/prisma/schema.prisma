datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

enum ProductType {
  MERCHANDISE
  TICKET_DIGITAL
  VIP_EXPERIENCE
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  SHIPPED
  REFUNDED
}

model User {
  id               String                @id @default(uuid()) @db.Uuid
  email            String                @unique
  passwordHash     String                @map("password_hash")
  roleId           Int                   @map("role_id")
  role             Role                  @relation(fields: [roleId], references: [id])
  stripeCustomerId String?               @unique @map("stripe_customer_id")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  orders           Order[]
  contributions    SupportContribution[]
  checkins         ConcertCheckIn[]
  auditLogs        AuditLog[]
  downloads        Download[]

  @@index([roleId])
  @@map("users")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  permissions Json
  users       User[]

  @@map("roles")
}

model Artist {
  id          String   @id @default(uuid()) @db.Uuid
  stageName   String   @map("stage_name")
  slug        String   @unique
  bio         String?
  socialLinks Json     @map("social_links")
  albums      Album[]
  events      Event[]

  @@map("artists")
}

model Album {
  id            String   @id @default(uuid()) @db.Uuid
  artistId      String   @map("artist_id") @db.Uuid
  artist        Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  title         String
  priceCents    Int      @map("price_cents")
  releaseDate   DateTime @map("release_date")
  coverImageUrl String   @map("cover_image_url")
  songs         Song[]

  @@index([artistId])
  @@map("albums")
}

model Song {
  id              String   @id @default(uuid()) @db.Uuid
  albumId         String   @map("album_id") @db.Uuid
  album           Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  title           String
  trackNumber     Int      @map("track_number")
  audioUrl        String   @map("audio_url")
  durationSeconds Int      @map("duration_seconds")

  @@index([albumId])
  @@map("songs")
}

model Product {
  id            String      @id @default(uuid()) @db.Uuid
  type          ProductType
  title         String
  priceCents    Int         @map("price_cents")
  sku           String      @unique
  stockQuantity Int         @map("stock_quantity")
  imageUrl      String?     @map("image_url")
  orderItems    OrderItem[]
  downloads     Download[]

  @@map("products")
}

model Event {
  id            String                @id @default(uuid()) @db.Uuid
  artistId      String                @map("artist_id") @db.Uuid
  artist        Artist                @relation(fields: [artistId], references: [id], onDelete: Cascade)
  title         String
  venueName     String                @map("venue_name")
  venueAddress  String                @map("venue_address")
  eventDate     DateTime              @map("event_date")
  tickets       Ticket[]
  contributions SupportContribution[]
  checkins      ConcertCheckIn[]
  eventState    EventState?

  @@index([artistId])
  @@map("events")
}

model Order {
  id                    String        @id @default(uuid()) @db.Uuid
  orderNumber           String?       @unique @map("order_number")
  userId                String        @map("user_id") @db.Uuid
  user                  User          @relation(fields: [userId], references: [id])
  status                OrderStatus   @default(PENDING)
  totalAmountCents      Int           @map("total_amount_cents")
  taxCents              Int           @default(0) @map("tax_cents")
  discountCents         Int           @default(0) @map("discount_cents")
  shippingCents         Int           @default(0) @map("shipping_cents")
  stripeSessionId       String?       @unique @map("stripe_session_id")
  stripePaymentIntentId String?       @unique @map("stripe_payment_intent_id")
  receiptUrl            String?       @map("receipt_url")
  refundStatus          String?       @map("refund_status")
  fulfillmentStatus     String        @default("PENDING") @map("fulfillment_status")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")
  orderItems            OrderItem[]
  payments              Payment[]
  transactions          Transaction[]
  downloads             Download[]

  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id             String   @id @default(uuid()) @db.Uuid
  orderId        String   @map("order_id") @db.Uuid
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String   @map("product_id") @db.Uuid
  product        Product  @relation(fields: [productId], references: [id])
  quantity       Int
  unitPriceCents Int      @map("unit_price_cents")
  tickets        Ticket[]

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Ticket {
  id          String    @id @default(uuid()) @db.Uuid
  orderItemId String    @map("order_item_id") @db.Uuid
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  eventId     String    @map("event_id") @db.Uuid
  event       Event     @relation(fields: [eventId], references: [id])
  qrCodeHash  String    @unique @map("qr_code_hash")
  isScanned   Boolean   @default(false) @map("is_scanned")
  scannedAt   DateTime? @map("scanned_at")

  @@index([orderItemId])
  @@index([eventId])
  @@map("tickets")
}

model ContentPost {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  slug        String   @unique
  bodyHtml    String   @map("body_html")
  type        String
  publishedAt DateTime @map("published_at")

  @@map("content_posts")
}

model SupportContribution {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String?  @map("user_id") @db.Uuid
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountCents     Int      @map("amount_cents")
  eventId         String?  @map("event_id") @db.Uuid
  event           Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  stripeSessionId String?  @unique @map("stripe_session_id")
  email           String?
  phone           String?
  comment         String?
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([eventId])
  @@map("support_contributions")
}

model ConcertCheckIn {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId   String   @map("event_id") @db.Uuid
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId])
  @@map("concert_checkins")
}

model EventState {
  id               String   @id @default(uuid()) @db.Uuid
  eventId          String   @unique @map("event_id") @db.Uuid
  event            Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  currentSongId    String?  @map("current_song_id")
  currentSongIndex Int      @default(0) @map("current_song_index")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("event_states")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  details   String
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@map("audit_logs")
}

model Payment {
  id                    String   @id @default(uuid()) @db.Uuid
  orderId               String   @map("order_id") @db.Uuid
  order                 Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  stripePaymentIntentId String?  @map("stripe_payment_intent_id")
  amountCents           Int      @map("amount_cents")
  currency              String   @default("usd")
  status                String   // succeeded, failed, refunded, processing, etc.
  receiptUrl            String?  @map("receipt_url")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@index([orderId])
  @@map("payments")
}

model Transaction {
  id              String   @id @default(uuid()) @db.Uuid
  orderId         String?  @map("order_id") @db.Uuid
  order           Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type            String   // CHARGE, REFUND, DONATION
  amountCents     Int      @map("amount_cents")
  stripeSessionId String?  @map("stripe_session_id")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([orderId])
  @@map("transactions")
}

model Download {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId       String?  @map("order_id") @db.Uuid
  order         Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String   @map("product_id") @db.Uuid
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  downloadToken String   @unique @map("download_token")
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([orderId])
  @@index([productId])
  @@map("downloads")
}

model RevenueReport {
  id                String   @id @default(uuid()) @db.Uuid
  date              DateTime @unique // The day this report represents (start of day)
  grossRevenueCents Int      @map("gross_revenue_cents")
  netRevenueCents   Int      @map("net_revenue_cents")
  salesCents        Int      @map("sales_cents")
  donationsCents    Int      @map("donations_cents")
  refundsCents      Int      @map("refunds_cents")
  orderCount        Int      @map("order_count")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("revenue_reports")
}

model AnalyticsEvent {
  id        String   @id @default(uuid()) @db.Uuid
  eventType String   @map("event_type") // PAGE_VIEW, CHECKOUT_INIT, CHECKOUT_SUCCESS, TICKET_SCAN, etc.
  details   String?  // JSON string or description
  userId    String?  @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  @@index([eventType])
  @@index([userId])
  @@map("analytics_events")
}

model ProcessedStripeEvent {
  id        String   @id @default(uuid()) @db.Uuid
  eventId   String   @unique @map("event_id")
  eventType String   @map("event_type")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("processed_stripe_events")
}
