datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

enum ProductType {
  MERCHANDISE
  TICKET_DIGITAL
  VIP_EXPERIENCE
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  SHIPPED
  REFUNDED
}

model User {
  id            String                @id @default(uuid()) @db.Uuid
  email         String                @unique
  passwordHash  String                @map("password_hash")
  roleId        Int                   @map("role_id")
  role          Role                  @relation(fields: [roleId], references: [id])
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")
  orders        Order[]
  contributions SupportContribution[]
  checkins      ConcertCheckIn[]

  @@index([roleId])
  @@map("users")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  permissions Json
  users       User[]

  @@map("roles")
}

model Artist {
  id          String   @id @default(uuid()) @db.Uuid
  stageName   String   @map("stage_name")
  slug        String   @unique
  bio         String?
  socialLinks Json     @map("social_links")
  albums      Album[]
  events      Event[]

  @@map("artists")
}

model Album {
  id            String   @id @default(uuid()) @db.Uuid
  artistId      String   @map("artist_id") @db.Uuid
  artist        Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  title         String
  priceCents    Int      @map("price_cents")
  releaseDate   DateTime @map("release_date")
  coverImageUrl String   @map("cover_image_url")
  songs         Song[]

  @@index([artistId])
  @@map("albums")
}

model Song {
  id              String   @id @default(uuid()) @db.Uuid
  albumId         String   @map("album_id") @db.Uuid
  album           Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  title           String
  trackNumber     Int      @map("track_number")
  audioUrl        String   @map("audio_url")
  durationSeconds Int      @map("duration_seconds")

  @@index([albumId])
  @@map("songs")
}

model Product {
  id            String      @id @default(uuid()) @db.Uuid
  type          ProductType
  title         String
  priceCents    Int         @map("price_cents")
  sku           String      @unique
  stockQuantity Int         @map("stock_quantity")
  orderItems    OrderItem[]

  @@map("products")
}

model Event {
  id            String                @id @default(uuid()) @db.Uuid
  artistId      String                @map("artist_id") @db.Uuid
  artist        Artist                @relation(fields: [artistId], references: [id], onDelete: Cascade)
  title         String
  venueName     String                @map("venue_name")
  venueAddress  String                @map("venue_address")
  eventDate     DateTime              @map("event_date")
  tickets       Ticket[]
  contributions SupportContribution[]
  checkins      ConcertCheckIn[]

  @@index([artistId])
  @@map("events")
}

model Order {
  id                    String      @id @default(uuid()) @db.Uuid
  userId                String      @map("user_id") @db.Uuid
  user                  User        @relation(fields: [userId], references: [id])
  status                OrderStatus @default(PENDING)
  totalAmountCents      Int         @map("total_amount_cents")
  stripePaymentIntentId String?     @unique @map("stripe_payment_intent_id")
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")
  orderItems            OrderItem[]

  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id             String   @id @default(uuid()) @db.Uuid
  orderId        String   @map("order_id") @db.Uuid
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String   @map("product_id") @db.Uuid
  product        Product  @relation(fields: [productId], references: [id])
  quantity       Int
  unitPriceCents Int      @map("unit_price_cents")
  tickets        Ticket[]

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Ticket {
  id          String    @id @default(uuid()) @db.Uuid
  orderItemId String    @map("order_item_id") @db.Uuid
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  eventId     String    @map("event_id") @db.Uuid
  event       Event     @relation(fields: [eventId], references: [id])
  qrCodeHash  String    @unique @map("qr_code_hash")
  isScanned   Boolean   @default(false) @map("is_scanned")
  scannedAt   DateTime? @map("scanned_at")

  @@index([orderItemId])
  @@index([eventId])
  @@map("tickets")
}

model ContentPost {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  slug        String   @unique
  bodyHtml    String   @map("body_html")
  type        String
  publishedAt DateTime @map("published_at")

  @@map("content_posts")
}

model SupportContribution {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String?  @map("user_id") @db.Uuid
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountCents     Int      @map("amount_cents")
  eventId         String?  @map("event_id") @db.Uuid
  event           Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  stripeSessionId String?  @unique @map("stripe_session_id")
  email           String?
  phone           String?
  comment         String?
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([eventId])
  @@map("support_contributions")
}

model ConcertCheckIn {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId   String   @map("event_id") @db.Uuid
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId])
  @@map("concert_checkins")
}
